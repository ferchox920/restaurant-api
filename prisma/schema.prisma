generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  AUDITOR
}

enum ProductUnit {
  UNIT
  PORTION
  SERVICE
}

enum StockManagementType {
  FINISHED_PRODUCT
  RECIPE_BASED
  NON_STOCKED
}

enum CommissionType {
  NONE
  PERCENTAGE
  FIXED
}

enum InventoryMovementType {
  STOCK_IN
  SALE_OUT
  MANUAL_ADJUSTMENT
  WASTE
  RETURN_IN
  VOID_REVERSAL
}

enum InventoryReferenceType {
  MANUAL
  SALE_TICKET
  SALE_VOID
  SYSTEM
}

enum SaleTicketStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  VOIDED
}

enum RestaurantTableOrderStatus {
  OPEN
  CANCELLED
  CLOSED
}

enum SalePaymentMethod {
  CASH
  TRANSFER
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  USER_REACTIVATED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DEACTIVATED
  CATEGORY_REACTIVATED
  SALES_CHANNEL_CREATED
  SALES_CHANNEL_UPDATED
  SALES_CHANNEL_DEACTIVATED
  SALES_CHANNEL_REACTIVATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DEACTIVATED
  PRODUCT_REACTIVATED
  PRODUCT_COST_CREATED
  PRODUCT_PRICE_CREATED
  INVENTORY_STOCK_IN
  INVENTORY_MANUAL_ADJUSTMENT
  INVENTORY_WASTE
  INVENTORY_RETURN_IN
  INVENTORY_SALE_OUT
  INVENTORY_VOID_REVERSAL
  INVENTORY_MINIMUM_STOCK_UPDATED
  PAYMENT_BANK_CREATED
  PAYMENT_BANK_UPDATED
  PAYMENT_BANK_DEACTIVATED
  PAYMENT_BANK_REACTIVATED
  SALE_TICKET_CREATED
  SALE_TICKET_UPDATED
  SALE_TICKET_CANCELLED
  SALE_TICKET_ITEM_ADDED
  SALE_TICKET_ITEM_UPDATED
  SALE_TICKET_ITEM_REMOVED
  SALE_TICKET_CONFIRMED
  SALE_TICKET_VOIDED
  RESTAURANT_TABLE_CREATED
  RESTAURANT_TABLE_UPDATED
  RESTAURANT_TABLE_DEACTIVATED
  RESTAURANT_TABLE_REACTIVATED
  TABLE_ORDER_OPENED
  TABLE_ORDER_CANCELLED
  TABLE_ORDER_CLOSED
}

enum AuditEntityType {
  USER
  CATEGORY
  SALES_CHANNEL
  PRODUCT
  PRODUCT_COST_HISTORY
  PRODUCT_PRICE_HISTORY
  PRODUCT_STOCK
  INVENTORY_MOVEMENT
  PAYMENT_BANK
  SALE_TICKET
  SALE_TICKET_ITEM
  RESTAURANT_TABLE
  TABLE_ORDER
  SYSTEM
}

model User {
  id                   String            @id @default(uuid()) @db.Uuid
  email                String            @unique
  passwordHash         String
  firstName            String
  lastName             String
  role                 Role
  active               Boolean           @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  auditLogs            AuditLog[]        @relation("AuditLogActor")
  createdTables        RestaurantTable[] @relation("RestaurantTableCreatedBy")
  openedTableOrders    TableOrder[]      @relation("TableOrderOpenedBy")
  cancelledTableOrders TableOrder[]      @relation("TableOrderCancelledBy")
  closedTableOrders    TableOrder[]      @relation("TableOrderClosedBy")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model SalesChannel {
  id              String                @id @default(uuid()) @db.Uuid
  name            String                @unique
  code            String                @unique
  description     String?
  commissionType  CommissionType        @default(NONE)
  commissionValue Decimal               @default(0) @db.Decimal(10, 2)
  active          Boolean               @default(true)
  createdById     String?               @db.Uuid
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  subTaxes        SalesChannelSubTax[]
  productPrices   ProductPriceHistory[]
  saleTickets     SaleTicket[]
}

model SalesChannelSubTax {
  id             String       @id @default(uuid()) @db.Uuid
  salesChannelId String       @db.Uuid
  name           String
  percentage     Decimal      @db.Decimal(5, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  salesChannel   SalesChannel @relation(fields: [salesChannelId], references: [id], onDelete: Cascade)

  @@unique([salesChannelId, name])
  @@index([salesChannelId])
}

model PaymentBank {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  description String?
  active      Boolean      @default(true)
  createdById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleTickets SaleTicket[]
}

model Product {
  id                  String                @id @default(uuid()) @db.Uuid
  name                String
  description         String?
  sku                 String?               @unique
  categoryId          String?               @db.Uuid
  unit                ProductUnit
  stockManagementType StockManagementType   @default(FINISHED_PRODUCT)
  active              Boolean               @default(true)
  createdById         String?               @db.Uuid
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  category            Category?             @relation(fields: [categoryId], references: [id])
  costHistory         ProductCostHistory[]
  priceHistory        ProductPriceHistory[]
  stock               ProductStock?
  inventoryMovements  InventoryMovement[]
  saleTicketItems     SaleTicketItem[]
}

model ProductStock {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @unique @db.Uuid
  currentStock Decimal  @default(0) @db.Decimal(10, 2)
  minimumStock Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id])
}

model InventoryMovement {
  id            String                 @id @default(uuid()) @db.Uuid
  productId     String                 @db.Uuid
  movementType  InventoryMovementType
  quantity      Decimal                @db.Decimal(10, 2)
  previousStock Decimal                @db.Decimal(10, 2)
  newStock      Decimal                @db.Decimal(10, 2)
  reason        String
  referenceType InventoryReferenceType @default(MANUAL)
  referenceId   String?
  createdById   String?                @db.Uuid
  createdAt     DateTime               @default(now())
  product       Product                @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
  @@index([productId, createdAt])
  @@index([referenceType, createdAt])
  @@index([createdById, createdAt])
}

model ProductCostHistory {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @db.Uuid
  cost        Decimal   @db.Decimal(10, 2)
  validFrom   DateTime
  validTo     DateTime?
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([productId, validTo])
}

model ProductPriceHistory {
  id             String       @id @default(uuid()) @db.Uuid
  productId      String       @db.Uuid
  salesChannelId String       @db.Uuid
  price          Decimal      @db.Decimal(10, 2)
  validFrom      DateTime
  validTo        DateTime?
  createdById    String?      @db.Uuid
  createdAt      DateTime     @default(now())
  product        Product      @relation(fields: [productId], references: [id])
  salesChannel   SalesChannel @relation(fields: [salesChannelId], references: [id])

  @@index([salesChannelId])
  @@index([productId, salesChannelId, validTo])
}

model SaleTicket {
  id                      String             @id @default(uuid()) @db.Uuid
  ticketNumber            Int                @unique @default(autoincrement())
  salesChannelId          String             @db.Uuid
  paymentMethod           SalePaymentMethod?
  paymentBankId           String?            @db.Uuid
  paymentBankNameSnapshot String?
  status                  SaleTicketStatus   @default(DRAFT)
  subtotal                Decimal            @default(0) @db.Decimal(10, 2)
  discountTotal           Decimal            @default(0) @db.Decimal(10, 2)
  commissionTotal         Decimal            @default(0) @db.Decimal(10, 2)
  total                   Decimal            @default(0) @db.Decimal(10, 2)
  notes                   String?
  createdById             String?            @db.Uuid
  confirmedById           String?            @db.Uuid
  cancelledById           String?            @db.Uuid
  voidedById              String?            @db.Uuid
  cancellationReason      String?
  voidReason              String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  confirmedAt             DateTime?
  cancelledAt             DateTime?
  voidedAt                DateTime?
  salesChannel            SalesChannel       @relation(fields: [salesChannelId], references: [id])
  paymentBank             PaymentBank?       @relation(fields: [paymentBankId], references: [id])
  items                   SaleTicketItem[]
  tableOrder              TableOrder?

  @@index([salesChannelId])
  @@index([paymentBankId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([confirmedAt])
  @@index([status, confirmedAt])
  @@index([salesChannelId, status, confirmedAt])
}

model SaleTicketItem {
  id                  String      @id @default(uuid()) @db.Uuid
  ticketId            String      @db.Uuid
  productId           String      @db.Uuid
  productNameSnapshot String
  productSkuSnapshot  String?
  productUnitSnapshot ProductUnit
  quantity            Decimal     @db.Decimal(10, 2)
  unitPriceSnapshot   Decimal     @db.Decimal(10, 2)
  unitCostSnapshot    Decimal     @db.Decimal(10, 2)
  subtotal            Decimal     @db.Decimal(10, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  ticket              SaleTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product             Product     @relation(fields: [productId], references: [id])

  @@index([ticketId])
  @@index([productId])
}

model RestaurantTable {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String?
  area        String?
  capacity    Int?
  active      Boolean      @default(true)
  createdById String?      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User?        @relation("RestaurantTableCreatedBy", fields: [createdById], references: [id])
  orders      TableOrder[]

  @@index([active])
  @@index([area])
}

model TableOrder {
  id                String                     @id @default(uuid()) @db.Uuid
  restaurantTableId String                     @db.Uuid
  saleTicketId      String                     @unique @db.Uuid
  status            RestaurantTableOrderStatus @default(OPEN)
  openedById        String?                    @db.Uuid
  cancelledById     String?                    @db.Uuid
  closedById        String?                    @db.Uuid
  notes             String?
  cancelReason      String?
  openedAt          DateTime                   @default(now())
  cancelledAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  restaurantTable   RestaurantTable            @relation(fields: [restaurantTableId], references: [id])
  saleTicket        SaleTicket                 @relation(fields: [saleTicketId], references: [id])
  openedBy          User?                      @relation("TableOrderOpenedBy", fields: [openedById], references: [id])
  cancelledBy       User?                      @relation("TableOrderCancelledBy", fields: [cancelledById], references: [id])
  closedBy          User?                      @relation("TableOrderClosedBy", fields: [closedById], references: [id])

  @@index([restaurantTableId])
  @@index([status])
  @@index([openedById])
  @@index([openedAt])
  @@index([restaurantTableId, status])
}

model SystemMetadata {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String?         @db.Uuid
  action     AuditAction
  entityType AuditEntityType
  entityId   String?
  beforeData Json?
  afterData  Json?
  metadata   Json?
  createdAt  DateTime        @default(now())
  user       User?           @relation("AuditLogActor", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
